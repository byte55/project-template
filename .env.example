# Copy to .env and adjust. Read by the dev docker-compose stack.

# ── Host ports ──
# Only change these if the defaults collide with another local project.
# Container-internal ports stay fixed (API 4000, Web 3100, Postgres 5432).
WEB_PORT=3100
API_PORT=4000
POSTGRES_PORT=5434
REDIS_PORT=6379
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# ── URLs / connection (only relevant for `pnpm dev:local` without Docker;
#    in the Docker stack, docker-compose.yml sets these values itself) ──
DATABASE_URL=postgresql://app:app@localhost:5434/app
REDIS_URL=redis://localhost:6379
WEB_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Auth ──
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=dev-secret-change-me
