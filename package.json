{
  "name": "app",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:local": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @app/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
